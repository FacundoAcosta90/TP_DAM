<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="techfield_database.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1852"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="clientes" custom_title="0" dock_id="1" table="4,8:mainclientes"/><dock_state state="000000ff00000000fd00000001000000020000000000000000fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000ffffffff0000011300ffffff000000000000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">PRAGMA foreign_keys = ON;

CREATE TABLE tecnicos (
    id INTEGER PRIMARY KEY,
    nombre_completo TEXT,
    usuario TEXT,
    password TEXT,
    rol TEXT
);

CREATE TABLE clientes (
    cliente_id INTEGER PRIMARY KEY AUTOINCREMENT,
    nombre_empresa TEXT,
    cuit TEXT,
    direccion TEXT,
    sucursal TEXT,
    sector TEXT,
    telefono_contacto TEXT,
    email_soporte TEXT
);

CREATE TABLE maquinas (
    nro_de_serie TEXT PRIMARY KEY,
    articulo TEXT,
    denominacion_comercial TEXT,
    direccion TEXT,
    sucursal TEXT,
    sector TEXT,
    observaciones TEXT
);

CREATE TABLE stock_repuestos (
    nro_serie_repuesto TEXT PRIMARY KEY,
    nombre_repuesto TEXT,
    estado TEXT,
    precio_unitario REAL
);

CREATE TABLE tickets (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    maquina_nro_serie TEXT,
    fecha_creacion TEXT,
    falla_reportada TEXT,
    estado TEXT,
    tecnico_id INTEGER,
    criticidad TEXT,
    FOREIGN KEY(maquina_nro_serie) REFERENCES maquinas(nro_de_serie),
    FOREIGN KEY(tecnico_id) REFERENCES tecnicos(id)
);

CREATE TABLE repuestos_utilizados (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    ticket_id INTEGER,
    nro_serie_repuesto TEXT,
    FOREIGN KEY(ticket_id) REFERENCES tickets(id),
    FOREIGN KEY(nro_serie_repuesto) REFERENCES stock_repuestos(nro_serie_repuesto)
);

CREATE TABLE evidencias_fotograficas (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    ticket_id INTEGER,
    foto_uri TEXT,
    FOREIGN KEY(ticket_id) REFERENCES tickets(id)
);

